##
# Example configuration for Drupal Canvas CLI.
##

CANVAS_SITE_URL=https://example.com

# Follow this guide to set up the Canvas OAuth module for authentication:
# https://git.drupalcode.org/project/canvas/-/tree/1.x/modules/canvas_oauth#2-setup
CANVAS_CLIENT_ID=cli
CANVAS_CLIENT_SECRET=secret

# Experimental. Uncomment to include pages in the CLI push/pull.
# CANVAS_INCLUDE_PAGES=true

# Experimental. Uncomment to include content templates in the CLI push/pull.
# CANVAS_INCLUDE_CONTENT_TEMPLATES=true
#
# Experimental. Uncomment to include global regions in the CLI push/pull.
# CANVAS_INCLUDE_REGIONS=true

# Only set if the default scopes from the `canvas_oauth` module are not used.
# CANVAS_SCOPE="canvas:js_component canvas:asset_library canvas:page:create canvas:page:read canvas:page:edit"

# Alternative to client credentials: provide a pre-issued Bearer token directly.
# When set, CANVAS_CLIENT_ID, CANVAS_CLIENT_SECRET, and CANVAS_SCOPE are ignored.
# CANVAS_ACCESS_TOKEN=your-access-token

# Set this if your JSON:API prefix (the part after the site URL) is configured
# differently from Drupal's default of `jsonapi`.
# CANVAS_JSONAPI_PREFIX=api
